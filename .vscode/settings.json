{
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    "python.languageServer": "Pylance",
    "editor.semanticHighlighting.enabled": true,
    "editor.hover.enabled": true,
    "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        // "rules": {
        //     "selfParameter:python": "#79C0FF",
        //     "clsParameter:python": "#79C0FF",
        //     "variable:python": "#E6EDF3",
        //     "parameter:python": "#FFA657",
        //     "property:python": "#79C0FF",
        //     "member:python": "#79C0FF",
        //     "function:python": "#D2A8FF",
        //     "method:python": "#D2A8FF",
        //     "magicFunction:python": "#FF7B72",
        //     "class:python": "#FFA657",
        //     "module:python": "#7EE787"
        // }
    },
    "python.analysis.indexing": true,
    "python.analysis.packageIndexDepths": [
        {
            "name": "numpy",
            "depth": 2,
            "includeAllSymbols": true
        }
    ],
    "python.analysis.languageServerMode": "default",
    "python.analysis.useLibraryCodeForTypes": true
}